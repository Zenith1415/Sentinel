GOOGLE_API_KEY=AIza...

# Backboard.io — recommended primary provider
# Unified API for 17,000+ LLMs with persistent memory. Sign up at backboard.io.
# Per-agent rate-limit spreading: configure separate assistants in the Backboard
# dashboard (each can use a different underlying model) and paste their UUIDs:
BACKBOARD_API_KEY=espr_...
BACKBOARD_ASSISTANT_PATCH=
BACKBOARD_ASSISTANT_SEMANTIC=
BACKBOARD_ASSISTANT_GOVERNANCE=
BACKBOARD_ASSISTANT_ID=

# Gemma 4 via Ollama — local, free inference (tier 2 fallback)
# Install: https://ollama.com  →  ollama pull gemma4:e2b
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DISABLE=1   # uncomment to skip the Ollama tier

RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
REDIS_URL=redis://localhost:6379
CHROMA_PATH=./chroma_db

# MongoDB Atlas Vector Search (optional — omit to use ChromaDB only)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=self_healing_contracts
MONGODB_DB_NAME=self_healing_contracts

# LangSmith tracing (optional but recommended for demos)
# Get your key at https://smith.langchain.com → Settings → API Keys
# Either naming convention works (legacy LANGCHAIN_* or current LANGSMITH_*):
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=self-healing-contracts
# Legacy aliases (still accepted):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=self-healing-contracts
